<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0/EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.thc.capstone.mapper.UserMapper">
    <select id="detail" parameterType="hashMap"
            resultType="com.thc.capstone.dto.UserDto$DetailResDto">
        SELECT user.id
             , user.deleted
             , user.created_at as createdAt
             , user.modified_at as modifiedAt

             , user.username
             , user.name
             , user.email
        FROM user
        WHERE user.id = #{id}
    </select>

    <!--  공통 WHERE 절  -->
    <!--  사용법  -->
    <!--  <include refid="commonWhere"/>  -->
    <sql id="commonWhere">
        WHERE user.id is not null
        <if test = "deleted != null">AND user.deleted = #{deleted}</if>
        <if test = "name != null and name !=''">AND user.name LIKE CONCAT('%', #{name}, '%')</if>
    </sql>

    <select id="list" parameterType="hashMap"
    resultType="com.thc.capstone.dto.UserDto$DetailResDto">
        SELECT user.id
        FROM user
        WHERE user.id is not null
        <include refid="commonWhere"/>
    </select>

</mapper>